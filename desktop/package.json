{
  "name": "server-monitor-desktop",
  "version": "1.0.0",
  "description": "服务器监控系统 - 桌面客户端",
  "main": "main.js",
  "author": "Server Monitor Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "release": "electron-builder --win --linux --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.servermonitor.app",
    "productName": "Server Monitor",
    "copyright": "Copyright © 2024 Server Monitor Team",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.png",
      "build/icon.ico"
    ],
    "publish": {
      "provider": "github",
      "owner": "5418814520666",
      "repo": "server-monitor",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Server-Monitor-Setup-${version}-${arch}.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Server Monitor",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Server-Monitor-${version}-${arch}.${ext}",
      "icon": "build/icon.png",
      "category": "Utility",
      "desktop": {
        "Name": "Server Monitor",
        "Comment": "服务器监控系统桌面客户端",
        "Categories": "Utility;System;"
      }
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    }
  }
}
